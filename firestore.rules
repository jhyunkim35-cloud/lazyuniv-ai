// Audited 2026-05-04 by Claude — verified per-user isolation
// All collections under users/{uid} are locked to request.auth.uid == uid.
// analysisSessions are written exclusively via Admin SDK (api/claude.js);
// TTL deletes are system-managed — both bypass rules. No client access permitted.
// Hardened 2026-05-04 (P0-1): users/{uid} parent doc is now read-only for clients.
// plan/planExpiry writes go through Admin SDK (api/toss.js, api/claude.js) only.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Explicit default deny — nothing is readable/writable unless matched below.
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      // User profile doc (payment state, singlePurchases, etc.) — read-only for clients.
      // Writes go through Admin SDK (api/toss.js, api/claude.js) only.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /folders/{folderId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /transcripts/{transcriptId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /srsCards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /timetable/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /gamification/state {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /quizResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // STT entitlements (Toss-paid Google STT credits).
      // Read-only for the owner (so the client can show "remaining credits").
      // Writes go through Admin SDK (api/toss.js creates on payment confirm,
      // api/google-stt.js marks consumed) — never from the client.
      match /sttEntitlements/{entitlementId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Per-month usage analytics (api/_usage.js writes via Admin SDK).
      // Read-only for the owner (admin dashboard reads via Admin too).
      match /usage/{ymd} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Payment idempotency log — server seals each paymentKey here so
      // retries are no-ops. Owner can read (e.g. payment history view).
      // Server-only writes via Admin SDK in api/toss.js.
      match /paymentLog/{paymentKey} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // analysisSessions: Admin SDK + TTL only. No client reads or writes.
      match /analysisSessions/{sessionId} {
        allow read, write: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // Shared collections (top-level) — multi-user features.
    // Membership lives in `memberUids` (array). Reads gate on that array.
    // Writes that mutate membership go through Admin SDK endpoints
    // (api/group-join.js, api/room-join.js) with invite-token checks —
    // direct client writes to memberUids are rejected.
    // ─────────────────────────────────────────────────────────────────

    // Cost-splitting groups for shared STT/recording purchases.
    // Creator pays first (Toss), STT runs immediately, friends settle later.
    match /lectureGroups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      // Create: caller must be the creator AND the only initial member.
      // Other invariants (totalCost > 0, inviteToken length, etc.) are
      // enforced by the create endpoint via Admin SDK; rules only assert
      // the caller-identity surface.
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.memberUids.size() == 1
        && request.resource.data.memberUids[0] == request.auth.uid;

      // Update: creator may only flip `status` (e.g. archive). Member
      // additions/removals must go through Admin SDK.
      allow update: if request.auth != null
        && resource.data.creatorUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      allow delete: if false;

      // Per-member settlement state (paid Y/N, share amount, etc.).
      // Anyone in the group reads; each member writes only their own row,
      // and only while the group is still active — once archived,
      // settlement state is frozen (UI already disables the editor, but
      // we close the console bypass at the rules layer too).
      match /members/{memberUid} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lectureGroups/$(groupId)).data.memberUids;
        allow write: if request.auth != null
          && request.auth.uid == memberUid
          && get(/databases/$(database)/documents/lectureGroups/$(groupId)).data.status == 'active';
      }

      // Shared recording metadata (currently just one doc: `recording/meta`).
      // `recording` is a *collection*, so we must match docs inside it —
      // a bare `match /recording { ... }` would target a single doc named
      // "recording" and silently miss `recording/meta`, defaulting to deny.
      match /recording/{docId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lectureGroups/$(groupId)).data.memberUids;
        allow write: if false;
      }
    }

    // Study rooms — same-lecture peers share study time + progress only.
    // Note CONTENT is never shared here; only minutes/progress counters.
    match /studyRooms/{roomId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberUids;

      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberUids.size() == 1
        && request.resource.data.memberUids[0] == request.auth.uid;

      // Owner can flip status; member additions go via Admin SDK.
      allow update: if request.auth != null
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      allow delete: if false;

      // Per-member study counters: studyMinutes, notesCount, progressPct,
      // lastActiveAt. All members can READ each other (the whole point).
      // Only the member themselves can WRITE their own row.
      match /members/{memberUid} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/studyRooms/$(roomId)).data.memberUids;
        allow write: if request.auth != null && request.auth.uid == memberUid;
      }
    }
  }
}
