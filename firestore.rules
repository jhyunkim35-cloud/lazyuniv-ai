// Audited 2026-05-04 by Claude — verified per-user isolation
// All collections under users/{uid} are locked to request.auth.uid == uid.
// analysisSessions are written exclusively via Admin SDK (api/claude.js);
// TTL deletes are system-managed — both bypass rules. No client access permitted.
// Hardened 2026-05-04 (P0-1): users/{uid} parent doc is now read-only for clients.
// plan/planExpiry writes go through Admin SDK (api/toss.js, api/claude.js) only.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Explicit default deny — nothing is readable/writable unless matched below.
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{uid} {
      // User profile doc (payment state, singlePurchases, etc.) — read-only for clients.
      // Writes go through Admin SDK (api/toss.js, api/claude.js) only.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /folders/{folderId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /transcripts/{transcriptId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /srsCards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /timetable/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /gamification/state {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /quizResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // STT entitlements (Toss-paid Google STT credits).
      // Read-only for the owner (so the client can show "remaining credits").
      // Writes go through Admin SDK (api/toss.js creates on payment confirm,
      // api/google-stt.js marks consumed) — never from the client.
      match /sttEntitlements/{entitlementId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Per-month usage analytics (api/_usage.js writes via Admin SDK).
      // Read-only for the owner (admin dashboard reads via Admin too).
      match /usage/{ymd} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // Payment idempotency log — server seals each paymentKey here so
      // retries are no-ops. Owner can read (e.g. payment history view).
      // Server-only writes via Admin SDK in api/toss.js.
      match /paymentLog/{paymentKey} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // analysisSessions: Admin SDK + TTL only. No client reads or writes.
      match /analysisSessions/{sessionId} {
        allow read, write: if false;
      }
    }
  }
}
